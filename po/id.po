#: sh/hivexsh.c:161
#, c-format
msgid ""
"\n"
"Welcome to hivexsh, the hivex interactive shell for examining\n"
"Windows Registry binary hive files.\n"
"\n"
"Type: 'help' for help summary\n"
"      'quit' to quit the shell\n"
"\n"
msgstr ""
"\n"
"Selamat datang di hivexsh, shell interaktif hivex untuk memeriksa\n"
"berkas hive biner Registri Windows.\n"
"\n"
"Ketik: 'help' untuk ringkasan bantuan\n"
"      'quit' untuk keluar dari shell\n"
"\n"

#: sh/hivexsh.c:275
#, c-format
msgid "hivexsh: error getting parent of node %zu\n"
msgstr "hivexsh: kesalahan saat mengambil induk dari node %zu\n"

#: sh/hivexsh.c:285
#, c-format
msgid "hivexsh: error getting node name of node %zx\n"
msgstr "hivexsh: kesalahan saat mengambil nama node dari node %zx\n"

#: sh/hivexsh.c:424
#, c-format
msgid "hivexsh: you must load a hive file first using 'load hivefile'\n"
msgstr ""
"hivexsh: Anda harus memuat berkas hive terlebih dahulu menggunakan 'load "
"hivefile'\n"

#: sh/hivexsh.c:445
#, c-format
msgid "hivexsh: unknown command '%s', use 'help' for help summary\n"
msgstr ""
"hivexsh: perintah tidak dikenal '%s', gunakan 'help' untuk ringkasan "
"bantuan\n"

#: sh/hivexsh.c:455
#, c-format
msgid "hivexsh: load: no hive file name given to load\n"
msgstr "hivexsh: load: tidak ada nama berkas hive yang diberikan untuk dimuat\n"

#: sh/hivexsh.c:471
#, c-format
msgid ""
"hivexsh: failed to open hive file: %s: %m\n"
"\n"
"If you think this file is a valid Windows binary hive file (_not_\n"
"a regedit *.reg file) then please run this command again using the\n"
"hivexsh option '-d' and attach the complete output _and_ the hive file\n"
"which fails into a bug report at https://bugzilla.redhat.com/\n"
"\n"
msgstr ""
"hivexsh: gagal membuka berkas hive: %s: %m  \n"
"\n"
"Jika Anda yakin berkas ini adalah berkas hive biner Windows yang valid "
"(_bukan_ berkas regedit *.reg) maka silakan jalankan kembali perintah ini "
"menggunakan opsi hivexsh '-d' dan lampirkan keluaran lengkap _serta_ berkas "
"hive yang gagal ke laporan bug di https://bugzilla.redhat.com/\n"
"\n"

#: sh/hivexsh.c:504 sh/hivexsh.c:613 sh/hivexsh.c:1099
#, c-format
msgid "hivexsh: '%s' command should not be given arguments\n"
msgstr "hivexsh: perintah '%s' tidak boleh diberi argumen\n"

#: sh/hivexsh.c:546
#, c-format
msgid ""
"%s: %s: \\ characters in path are doubled - are you escaping the path "
"parameter correctly?\n"
msgstr ""
"%s: %s: karakter \\ dalam path digandakan - apakah Anda meloloskan parameter "
"path dengan benar?\n"

#: sh/hivexsh.c:584
#, c-format
msgid "hivexsh: cd: subkey '%s' not found\n"
msgstr "hivexsh: cd: subkey '%s' tidak ditemukan\n"

#: sh/hivexsh.c:602
#, c-format
msgid ""
"Navigate through the hive's keys using the 'cd' command, as if it\n"
"contained a filesystem, and use 'ls' to list the subkeys of the\n"
"current key.  Full documentation is in the hivexsh(1) manual page.\n"
msgstr ""
"Navigasikan melalui kunci hive menggunakan perintah 'cd', seolah-olah berisi "
"sistem berkas, dan gunakan 'ls' untuk menampilkan subkey dari kunci saat "
"ini. Dokumentasi lengkap ada di halaman manual hivexsh(1).\n"

#: sh/hivexsh.c:681
#, c-format
msgid "%s: %s: key not found\n"
msgstr "%s: %s: kunci tidak ditemukan\n"

#: sh/hivexsh.c:873 sh/hivexsh.c:977 sh/hivexsh.c:1003 sh/hivexsh.c:1032
#, c-format
msgid "%s: %s: invalid integer parameter (%s returned %u)\n"
msgstr "%s: %s: parameter bilangan bulat tidak valid (%s mengembalikan %u)\n"

#: sh/hivexsh.c:878 sh/hivexsh.c:983 sh/hivexsh.c:1009 sh/hivexsh.c:1038
#, c-format
msgid "%s: %s: integer out of range\n"
msgstr "%s: %s: bilangan bulat di luar jangkauan\n"

#: sh/hivexsh.c:900 sh/hivexsh.c:918
#, c-format
msgid "hivexsh: setval: unexpected end of input\n"
msgstr "hivexsh: setval: akhir masukan tidak terduga\n"

#: sh/hivexsh.c:939 sh/hivexsh.c:958
#, c-format
msgid ""
"hivexsh: string(utf16le): only 7 bit ASCII strings are supported for input\n"
msgstr ""
"hivexsh: string(utf16le): hanya string ASCII 7 bit yang didukung untuk "
"masukan\n"

#: sh/hivexsh.c:1069
#, c-format
msgid "hivexsh: setval: trailing garbage after hex string\n"
msgstr "hivexsh: setval: sampah tersisa setelah string heksadesimal\n"

#: sh/hivexsh.c:1076
#, c-format
msgid ""
"hivexsh: setval: cannot parse value string, please refer to the man page "
"hivexsh(1) for help: %s\n"
msgstr ""
"hivexsh: setval: tidak dapat mengurai string nilai, silakan merujuk ke "
"halaman manual hivexsh(1) untuk bantuan: %s\n"

#: sh/hivexsh.c:1105
#, c-format
msgid "hivexsh: del: the root node cannot be deleted\n"
msgstr "hivexsh: del: node root tidak dapat dihapus\n"

#: xml/hivexml.c:80
#, c-format
msgid "%s: failed to write XML document\n"
msgstr "%s: gagal menulis dokumen XML\n"

#: xml/hivexml.c:116
#, c-format
msgid "hivexml: missing name of input file\n"
msgstr "hivexml: nama berkas masukan hilang\n"

#: xml/hivexml.c:135
#, c-format
msgid "xmlNewTextWriterFilename: failed to create XML writer\n"
msgstr "xmlNewTextWriterFilename: gagal membuat penulis XML\n"
